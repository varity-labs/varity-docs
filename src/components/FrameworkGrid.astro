---
/**
 * FrameworkGrid Component
 *
 * "Works with your stack" — recognizable framework logos plus the full
 * auto-detected support matrix (Node + Python + static), grouped.
 */

const logos = [
  {
    name: 'Next.js',
    href: '/getting-started/quickstart-nextjs/',
    logo: `<svg viewBox="0 0 180 180" fill="none" xmlns="http://www.w3.org/2000/svg"><mask id="nx" style="mask-type:alpha" maskUnits="userSpaceOnUse" x="0" y="0" width="180" height="180"><circle cx="90" cy="90" r="90" fill="#000"/></mask><g mask="url(#nx)"><circle cx="90" cy="90" r="90" fill="#000"/><path d="M149.508 157.52L69.142 54H54v71.97h12.114V69.384l73.885 95.461a90.304 90.304 0 009.509-7.325z" fill="url(#nxb)"/><rect x="115" y="54" width="12" height="72" fill="url(#nxc)"/></g><defs><linearGradient id="nxb" x1="109" y1="116.5" x2="144.5" y2="160.5" gradientUnits="userSpaceOnUse"><stop stop-color="#fff"/><stop offset="1" stop-color="#fff" stop-opacity="0"/></linearGradient><linearGradient id="nxc" x1="121" y1="54" x2="120.799" y2="106.875" gradientUnits="userSpaceOnUse"><stop stop-color="#fff"/><stop offset="1" stop-color="#fff" stop-opacity="0"/></linearGradient></defs></svg>`,
  },
  {
    name: 'React',
    href: '/getting-started/quickstart/',
    logo: `<svg viewBox="-11.5 -10.232 23 20.463" xmlns="http://www.w3.org/2000/svg"><circle r="2.05" fill="#61dafb"/><g stroke="#61dafb" fill="none"><ellipse rx="11" ry="4.2"/><ellipse rx="11" ry="4.2" transform="rotate(60)"/><ellipse rx="11" ry="4.2" transform="rotate(120)"/></g></svg>`,
  },
  {
    name: 'Vue',
    href: '/getting-started/quickstart/',
    logo: `<svg viewBox="0 0 256 221" xmlns="http://www.w3.org/2000/svg"><path fill="#41B883" d="M204.8 0H256L128 220.8 0 0h97.92L128 51.2 157.44 0z"/><path fill="#41B883" d="M0 0l128 220.8L256 0h-51.2L128 132.48 50.56 0z"/><path fill="#35495E" d="M50.56 0L128 133.12 204.8 0h-47.36L128 51.2 97.92 0z"/></svg>`,
  },
  {
    name: 'Python',
    href: '/getting-started/quickstart/',
    logo: `<svg viewBox="0 0 256 255" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="py1" x1="12.959%" y1="12.039%" x2="79.639%" y2="78.201%"><stop offset="0" stop-color="#387EB8"/><stop offset="1" stop-color="#366994"/></linearGradient><linearGradient id="py2" x1="19.128%" y1="20.579%" x2="90.742%" y2="88.429%"><stop offset="0" stop-color="#FFE052"/><stop offset="1" stop-color="#FFC331"/></linearGradient></defs><path fill="url(#py1)" d="M126.916.072c-64.832 0-60.784 28.115-60.784 28.115l.072 29.128h61.868v8.745H41.631S.145 61.355.145 126.77c0 65.417 36.21 63.097 36.21 63.097h21.61v-30.356s-1.165-36.21 35.632-36.21h61.362s34.475.557 34.475-33.319V33.97S194.67.072 126.916.072zM92.802 19.66a11.12 11.12 0 0111.13 11.13 11.12 11.12 0 01-11.13 11.13 11.12 11.12 0 01-11.13-11.13 11.12 11.12 0 0111.13-11.13z"/><path fill="url(#py2)" d="M128.757 254.126c64.832 0 60.784-28.115 60.784-28.115l-.072-29.127H127.6v-8.745h86.441s41.486 4.705 41.486-60.712c0-65.416-36.21-63.096-36.21-63.096h-21.61v30.355s1.165 36.21-35.632 36.21h-61.362s-34.475-.557-34.475 33.32v56.013s-5.235 33.897 62.518 33.897zm34.114-19.586a11.12 11.12 0 01-11.13-11.13 11.12 11.12 0 0111.13-11.131 11.12 11.12 0 0111.13 11.13 11.12 11.12 0 01-11.13 11.13z"/></svg>`,
  },
]

const more = {
  Node: ['Astro', 'Qwik', 'Vite', 'Express', 'Fastify', 'NestJS', 'Koa', 'Hono'],
  Python: ['FastAPI', 'Django', 'Flask'],
  Static: ['HTML'],
}
---

<div class="framework-grid not-content">
  <p class="framework-label">Works with your stack</p>
  <div class="framework-items">
    {logos.map(fw => (
      <a class="framework-item" href={fw.href}>
        <div class="framework-logo" set:html={fw.logo} />
        <span class="framework-name">{fw.name}</span>
      </a>
    ))}
  </div>
  <div class="framework-more">
    {Object.entries(more).map(([group, names]) => (
      <div class="framework-group">
        <span class="framework-group-label">{group}</span>
        <div class="framework-chips">
          {names.map(n => <span class="framework-chip">{n}</span>)}
        </div>
      </div>
    ))}
  </div>
  <p class="framework-note">All detected automatically, no configuration. <a href="/deploy/supported-frameworks/">See the full list</a>.</p>
</div>

<style>
  .framework-grid {
    text-align: center;
    margin: var(--space-6) 0;
  }

  .framework-label {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-weight: var(--font-semibold);
    margin-bottom: var(--space-5);
  }

  .framework-items {
    display: flex;
    justify-content: center;
    gap: var(--space-8);
    flex-wrap: wrap;
    margin-bottom: var(--space-6);
  }

  .framework-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: inherit;
    transition: transform var(--transition-fast);
  }

  .framework-item:hover {
    transform: translateY(-3px);
  }

  .framework-logo {
    width: 3rem;
    height: 3rem;
    transition: all var(--transition-fast);
  }

  .framework-logo :global(svg) {
    width: 100%;
    height: 100%;
  }

  .framework-item:hover .framework-logo {
    filter: drop-shadow(0 4px 12px rgba(20, 184, 166, 0.3));
  }

  .framework-name {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: var(--font-medium);
  }

  .framework-more {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 44rem;
    margin: 0 auto;
  }

  .framework-group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .framework-group-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--text-tertiary);
    font-weight: var(--font-semibold);
    min-width: 3.5rem;
    text-align: right;
  }

  .framework-chips {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: center;
  }

  .framework-chip {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    background: var(--surface-2, rgba(148, 163, 184, 0.1));
    border: 1px solid var(--border, rgba(148, 163, 184, 0.18));
    border-radius: 9999px;
    padding: 0.2rem 0.7rem;
    white-space: nowrap;
  }

  .framework-note {
    font-size: var(--text-sm);
    color: var(--text-tertiary);
    margin-top: var(--space-5);
  }

  @media (max-width: 48rem) {
    .framework-items {
      gap: var(--space-6);
    }

    .framework-logo {
      width: 2.5rem;
      height: 2.5rem;
    }

    .framework-group {
      flex-direction: column;
      gap: var(--space-2);
    }

    .framework-group-label {
      text-align: center;
    }
  }
</style>
