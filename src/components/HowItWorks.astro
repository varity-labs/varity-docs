---
/**
 * HowItWorks Component
 *
 * Visual 3-step flow: Install → Build → Deploy.
 * Numbered teal circles with connecting lines.
 * Uses simple flexbox with fixed heights for cross-column alignment.
 */

const steps = [
  {
    number: 1,
    title: 'Install',
    description: 'Add the SDK to any JavaScript project.',
    code: 'npm install @varity-labs/sdk',
  },
  {
    number: 2,
    title: 'Build',
    description: 'Use auth, database, storage, and payments.',
    code: "const users = db.collection('users');",
  },
  {
    number: 3,
    title: 'Deploy',
    description: 'Ship to production with one command.',
    code: 'varitykit deploy',
  },
]
---

<div class="how-it-works">
  <div class="steps-row">
    {steps.map((step, i) => (
      <div class="step-col">
        <div class="step-top">
          {i > 0 && <div class="connector connector-left" />}
          <div class="step-circle">
            <span>{step.number}</span>
          </div>
          {i < steps.length - 1 && <div class="connector connector-right" />}
        </div>
        <div class="step-title">{step.title}</div>
        <div class="step-desc">{step.description}</div>
        <div class="step-code">{step.code}</div>
      </div>
    ))}
  </div>
</div>

<style>
  .how-it-works {
    margin: 2.5rem 0;
  }

  .steps-row {
    display: flex;
    gap: 2rem;
  }

  .step-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Circle row — fixed height so all circles align */
  .step-top {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 48px;
    margin-bottom: 12px;
    flex-shrink: 0;
  }

  .step-circle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: rgba(20, 184, 166, 0.1);
    border: 2px solid #14b8a6;
    border-radius: 50%;
    color: #14b8a6;
    font-weight: 700;
    font-size: 1.125rem;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }

  .connector {
    position: absolute;
    top: 50%;
    height: 2px;
    background: rgba(63, 63, 70, 0.5);
  }

  .connector-left {
    left: 0;
    right: calc(50% + 32px);
  }

  .connector-right {
    left: calc(50% + 32px);
    right: 0;
  }

  /* Title — fixed height so descriptions start at same level */
  .step-title {
    font-size: 1.125rem;
    font-weight: 600;
    color: #fafafa;
    margin: 0 0 4px 0;
    height: 1.5em;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  /* Description — flex: 1 pushes code to bottom */
  .step-desc {
    font-size: 0.9375rem;
    color: #a1a1aa;
    line-height: 1.6;
    margin: 0 0 12px 0;
    flex: 1;
  }

  /* Code — anchored at bottom by flex: 1 on desc */
  .step-code {
    display: inline-block;
    font-family: var(--sl-font-mono, 'JetBrains Mono', monospace);
    box-sizing: border-box;
    font-size: 0.8125rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(63, 63, 70, 0.5);
    border-radius: 6px;
    padding: 8px 12px;
    color: #14b8a6;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    flex-shrink: 0;
  }

  /* Light mode */
  :global([data-theme="light"]) .step-title {
    color: #18181b;
  }

  :global([data-theme="light"]) .step-desc {
    color: #52525b;
  }

  :global([data-theme="light"]) .step-code {
    background: rgba(0, 0, 0, 0.03);
    border-color: rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 48rem) {
    .steps-row {
      flex-direction: column;
      gap: 2rem;
    }

    .connector {
      display: none;
    }

    .step-desc {
      flex: 0;
    }

    .step-title {
      height: auto;
    }
  }
</style>
