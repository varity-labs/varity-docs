---
/**
 * PageMeta Component
 * Displays author attribution, last updated date, and version info
 * Based on research: trust signals build credibility (E-E-A-T)
 */
interface Props {
  author?: string;
  authorRole?: string;
  lastUpdated?: string;
  version?: string;
  stability?: 'stable' | 'beta' | 'alpha' | 'experimental';
}

const {
  author,
  authorRole,
  lastUpdated,
  version,
  stability = 'stable'
} = Astro.props;

const stabilityColors = {
  stable: 'var(--color-success)',
  beta: 'var(--color-info)',
  alpha: 'var(--color-warning)',
  experimental: 'var(--color-danger)'
};

const stabilityBg = {
  stable: 'rgba(34, 197, 94, 0.1)',
  beta: 'rgba(59, 130, 246, 0.1)',
  alpha: 'rgba(245, 158, 11, 0.1)',
  experimental: 'rgba(239, 68, 68, 0.1)'
};
---

<div class="page-meta">
  {author && (
    <span class="meta-item author">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/>
        <circle cx="12" cy="7" r="4"/>
      </svg>
      <strong>{author}</strong>
      {authorRole && <span class="author-role">{authorRole}</span>}
    </span>
  )}

  {lastUpdated && (
    <span class="meta-item updated">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/>
        <polyline points="12 6 12 12 16 14"/>
      </svg>
      Updated {lastUpdated}
    </span>
  )}

  {version && (
    <span
      class="version-badge"
      style={`color: ${stabilityColors[stability]}; background: ${stabilityBg[stability]};`}
    >
      v{version} ({stability})
    </span>
  )}
</div>

<style>
  .page-meta {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 0;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-secondary);
    font-size: 0.8125rem;
    overflow-x: auto;
  }

  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  .meta-item svg {
    flex-shrink: 0;
    opacity: 0.7;
    width: 16px;
    height: 16px;
  }

  .meta-item strong {
    color: var(--text-secondary);
    font-weight: 500;
  }

  .author-role {
    color: var(--text-muted);
  }

  .author-role::before {
    content: ' · ';
  }

  .version-badge {
    display: inline-block;
    padding: 0.15em 0.5em;
    border-radius: var(--radius-sm);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    white-space: nowrap;
  }

  @media (max-width: 48rem) {
    .page-meta {
      flex-wrap: wrap;
    }
  }
</style>
