---
import { Icon } from '@astrojs/starlight/components';

const entryPaths = [
  {
    title: 'AI editor',
    href: '/ai-tools/mcp-server-spec/',
    icon: 'laptop',
    summary: 'Connect Claude Code, Cursor, Windsurf, or VS Code to the Varity MCP server.',
    action: 'Set up MCP',
    command: 'claude mcp add varity -- npx -y @varity-labs/mcp',
  },
  {
    title: 'Command line',
    href: '/getting-started/quickstart/',
    icon: 'seti:shell',
    summary: 'Install varitykit and deploy from a supported project folder.',
    action: 'Deploy with CLI',
    command: 'pipx install varitykit\nvaritykit app deploy',
  },
  {
    title: 'Dashboard',
    href: '/deploy/deploy-from-dashboard/',
    icon: 'rocket',
    summary: 'Deploy from the Developer Portal when you want a visual flow.',
    action: 'Open dashboard guide',
    command: 'developer.store.varity.so',
  },
  {
    title: 'Docker image',
    href: '/deploy/deploy-docker-image/',
    icon: 'seti:docker',
    summary: 'Deploy a public or private Docker or OCI HTTP service image.',
    action: 'Deploy an image',
    command: 'varitykit app deploy --image <ref>',
  },
] as const;

const platformGroups = [
  {
    title: 'Start',
    icon: 'rocket',
    description: 'Install Varity, connect your tool, and ship the first app.',
    links: [
      ['Install', '/getting-started/installation/'],
      ['Quickstart', '/getting-started/quickstart/'],
      ['What you can deploy', '/deploy/what-you-can-deploy/'],
    ],
  },
  {
    title: 'Deploy',
    icon: 'cloud-download',
    description: 'Choose source, Docker image, dashboard, or AI editor deploys.',
    links: [
      ['Deploy your app', '/deploy/deploy-your-app/'],
      ['Deploy a Docker image', '/deploy/deploy-docker-image/'],
      ['Deploy from AI editor', '/guides/deploy-from-ai-ide/'],
    ],
  },
  {
    title: 'Configure',
    icon: 'setting',
    description: 'Set runtime variables, credentials, services, and app URLs.',
    links: [
      ['Environment variables', '/deploy/env-variables/'],
      ['Managed credentials', '/deploy/managed-credentials/'],
      ['App URLs and names', '/deploy/custom-domains/'],
    ],
  },
  {
    title: 'Data and services',
    icon: 'seti:db',
    description: 'Understand databases, caches, object storage, and model runtimes.',
    links: [
      ['Auto wired services', '/deploy/auto-wired-services/'],
      ['Databases and data', '/deploy/databases/'],
      ['Supported frameworks', '/deploy/supported-frameworks/'],
    ],
  },
  {
    title: 'Operate',
    icon: 'list-format',
    description: 'Check deploy status, recover a version, and troubleshoot failures.',
    links: [
      ['Troubleshooting deploys', '/deploy/deployment-troubleshooting/'],
      ['Recover a previous version', '/deploy/rollback/'],
      ['CLI deploy command', '/cli/commands/deploy/'],
    ],
  },
  {
    title: 'Reference',
    icon: 'open-book',
    description: 'Use the exact public tool and API surfaces exposed to agents.',
    links: [
      ['MCP server tools', '/ai-tools/mcp-server-spec/'],
      ['API reference', '/ai-tools/api-reference/'],
      ['Glossary', '/resources/glossary/'],
    ],
  },
] as const;

const commonTasks = [
  ['Deploy a Next.js app', '/guides/deploy-nextjs/'],
  ['Deploy a Python app', '/getting-started/quickstart-python/'],
  ['Migration guide', '/deploy/vercel-migration/'],
  ['Set environment variables', '/deploy/env-variables/'],
  ['Estimate costs', '/resources/pricing/'],
  ['Get help', '/getting-started/getting-help/'],
];

const capabilityItems = [
  {
    label: 'Source projects',
    value: 'Node, Python, Go, and static stacks',
  },
  {
    label: 'Images',
    value: 'Public and private Docker or OCI HTTP services',
  },
  {
    label: 'Services',
    value: 'Postgres, Redis, MongoDB, MySQL, object storage, and model runtime',
  },
  {
    label: 'URLs',
    value: 'varity.app path and subdomain app URLs',
  },
];

const trustLinks = [
  ['Security', '/resources/security/'],
  ['Billing', '/resources/billing/'],
  ['Troubleshooting', '/resources/troubleshooting/'],
  ['Current beta boundaries', '/deploy/what-you-can-deploy/'],
];
---

<div class="docs-home not-content">
  <section class="docs-hero">
    <div class="hero-copy">
      <p class="eyebrow">Varity Docs</p>
      <h1>Deploy supported apps with predictable cloud hosting.</h1>
      <p class="lede">
        The practical reference for shipping source projects, Docker services, AI agent apps, and managed runtime services on Varity.
      </p>

      <div class="hero-actions">
        <a class="primary-action" href="/getting-started/quickstart/">
          <span>Start deploying</span>
          <Icon name="right-arrow" />
        </a>
        <a class="secondary-action" href="/ai-tools/mcp-server-spec/">
          <span>Set up MCP</span>
          <Icon name="right-arrow" />
        </a>
      </div>
    </div>

    <div class="hero-path-panel" aria-label="Varity first deploy paths">
      <div class="hero-panel-top">
        <span>Start path</span>
        <span>Current docs</span>
      </div>
      <div class="hero-path-list">
        {entryPaths.map((item) => (
          <a class="hero-path" href={item.href}>
            <span class="hero-path-icon"><Icon name={item.icon} /></span>
            <span class="hero-path-copy">
              <strong>{item.title}</strong>
              <small>{item.summary}</small>
            </span>
            <Icon name="right-arrow" />
          </a>
        ))}
      </div>
      <div class="hero-quickstart">
        <span>CLI quick start</span>
        <code>pipx install varitykit<br />varitykit app deploy</code>
      </div>
    </div>
  </section>

  <section class="entry-section" aria-labelledby="entry-title">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Choose your path</p>
        <h2 id="entry-title">Start from the tool you already use.</h2>
      </div>
      <p>
        Varity supports multiple entry points. Each route leads to the same live app workflow and the same public deployment URL.
      </p>
    </div>

    <div class="entry-grid">
      {entryPaths.map((item) => (
        <a class="entry-card" href={item.href}>
          <span class="icon-box"><Icon name={item.icon} /></span>
          <strong>{item.title}</strong>
          <p>{item.summary}</p>
          <code>{item.command}</code>
          <span class="card-link">
            {item.action}
            <Icon name="right-arrow" />
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="platform-section" aria-labelledby="platform-title">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Documentation map</p>
        <h2 id="platform-title">Find the page by what you are trying to do.</h2>
      </div>
      <p>
        The docs are organized around deployment, configuration, operation, and reference. This page is the index for the current product surface.
      </p>
    </div>

    <div class="platform-grid">
      {platformGroups.map((group) => (
        <div class="platform-card">
          <div class="platform-card-header">
            <span class="icon-box compact"><Icon name={group.icon} /></span>
            <h3>{group.title}</h3>
          </div>
          <p>{group.description}</p>
          <ul>
            {group.links.map(([label, href]) => (
              <li>
                <a href={href}>
                  <span>{label}</span>
                  <Icon name="right-arrow" />
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section class="workflow-section" aria-labelledby="workflow-title">
    <div class="workflow-panel">
      <div class="workflow-copy">
        <p class="section-kicker">How the deploy flow reads</p>
        <h2 id="workflow-title">From project to live URL.</h2>
        <p>
          Varity detects supported frameworks, selects static or dynamic hosting, applies runtime defaults, attaches detected services, and returns the public app URL.
        </p>
        <a href="/deploy/intelligent-orchestration/">
          Deployment defaults
          <Icon name="right-arrow" />
        </a>
      </div>

      <div class="workflow-steps" aria-label="Deployment flow">
        <div>
          <span>01</span>
          <strong>Provide source or image</strong>
          <p>Use a supported project, GitHub repo, dashboard input, MCP tool, or runnable image.</p>
        </div>
        <div>
          <span>02</span>
          <strong>Review generated settings</strong>
          <p>Confirm hosting mode, app name, port, variables, and detected services before shipping.</p>
        </div>
        <div>
          <span>03</span>
          <strong>Deploy and operate</strong>
          <p>Use status, logs, redeploy, environment updates, and support docs after launch.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="task-section" aria-labelledby="task-title">
    <div class="section-heading">
      <div>
        <p class="section-kicker">Common tasks</p>
        <h2 id="task-title">Shortcuts for frequent workflows.</h2>
      </div>
      <p>
        These are the pages users usually need while connecting tools, deploying apps, pricing workloads, and recovering from setup issues.
      </p>
    </div>

    <div class="task-grid">
      {commonTasks.map(([label, href]) => (
        <a href={href}>
          <span>{label}</span>
          <Icon name="right-arrow" />
        </a>
      ))}
    </div>
  </section>

  <section class="capability-section" aria-labelledby="capability-title">
    <div class="capability-card">
      <div>
        <p class="section-kicker">Current beta surface</p>
        <h2 id="capability-title">What is supported today.</h2>
        <p>
          Source deploys support Node, Python, Go, and static stacks. Other stacks can deploy with a prebuilt Docker or OCI HTTP service image. External custom domains, cron, preview deployments, and one click rollback are not shipped yet.
        </p>
      </div>
      <dl>
        {capabilityItems.map((item) => (
          <div>
            <dt>{item.label}</dt>
            <dd>{item.value}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <section class="trust-section" aria-labelledby="trust-title">
    <div>
      <p class="section-kicker">Run with clarity</p>
      <h2 id="trust-title">Security, billing, and support.</h2>
    </div>
    <div class="trust-links">
      {trustLinks.map(([label, href]) => (
        <a href={href}>
          <span>{label}</span>
          <Icon name="right-arrow" />
        </a>
      ))}
    </div>
  </section>
</div>

<style>
  .docs-home {
    --home-border: rgba(148, 163, 184, 0.22);
    --home-border-strong: rgba(148, 163, 184, 0.34);
    --home-card: rgba(255, 255, 255, 0.025);
    --home-card-hover: rgba(20, 184, 166, 0.06);
    --home-muted: var(--text-secondary);
    max-width: 96rem;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
  }

  :global(body:has(.docs-home) main > .content-panel:first-child) {
    display: none;
  }

  .docs-home a {
    text-decoration: none;
  }

  .docs-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(25rem, 1.05fr);
    gap: 3.5rem;
    align-items: center;
    padding-bottom: 3.5rem;
    border-bottom: 1px solid var(--home-border);
  }

  .hero-copy h1 {
    max-width: 18ch;
    margin: 0.75rem 0 1rem;
    color: var(--text-primary);
    font-size: 3.25rem;
    font-weight: 800;
    line-height: 1.04;
    letter-spacing: 0;
  }

  .eyebrow,
  .section-kicker {
    margin: 0;
    color: var(--color-brand);
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .lede {
    max-width: 44rem;
    margin: 0;
    color: var(--home-muted);
    font-size: 1.0625rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .primary-action,
  .secondary-action,
  .workflow-copy a,
  .card-link,
  .task-grid a,
  .trust-links a,
  .platform-card a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .primary-action,
  .secondary-action {
    min-height: 2.55rem;
    padding: 0 1rem;
    border-radius: 6px;
    font-weight: 700;
  }

  .primary-action {
    background: var(--color-brand);
    color: #031312;
  }

  .secondary-action {
    border: 1px solid var(--home-border-strong);
    color: var(--text-primary);
  }

  .hero-actions :global(svg),
  .workflow-copy :global(svg),
  .card-link :global(svg),
  .task-grid :global(svg),
  .trust-links :global(svg),
  .platform-card a :global(svg) {
    width: 1rem;
    height: 1rem;
    flex: none;
  }

  .hero-path-panel {
    border: 1px solid var(--home-border);
    border-radius: 8px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.015));
    overflow: hidden;
    box-shadow: 0 18px 52px rgba(0, 0, 0, 0.18);
  }

  .hero-panel-top {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.8rem 1rem;
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
    color: var(--home-muted);
    font-family: var(--sl-font-mono);
    font-size: 0.8125rem;
  }

  .hero-path-list {
    display: grid;
  }

  .hero-path {
    display: grid;
    grid-template-columns: 2.25rem minmax(0, 1fr) auto;
    gap: 0.9rem;
    align-items: center;
    min-height: 5.2rem;
    padding: 1rem;
    color: inherit;
    border-bottom: 1px solid rgba(148, 163, 184, 0.18);
    transition: background-color 150ms ease;
  }

  .hero-path:hover {
    background: var(--home-card-hover);
  }

  .hero-path :global(svg:last-child) {
    width: 1rem;
    height: 1rem;
    color: var(--home-muted);
  }

  .hero-path-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 8px;
    color: var(--color-brand);
  }

  .hero-path-icon :global(svg) {
    width: 1.1rem;
    height: 1.1rem;
  }

  .hero-path-copy {
    display: grid;
    gap: 0.25rem;
  }

  .hero-path-copy strong {
    color: var(--text-primary);
    font-size: 0.98rem;
    line-height: 1.3;
  }

  .hero-path-copy small {
    color: var(--home-muted);
    font-size: 0.84rem;
    line-height: 1.45;
  }

  .hero-quickstart {
    display: grid;
    grid-template-columns: 9rem minmax(0, 1fr);
    gap: 1rem;
    align-items: center;
    padding: 1rem;
  }

  .hero-quickstart span {
    color: var(--home-muted);
    font-size: 0.82rem;
    font-weight: 700;
  }

  .hero-quickstart code {
    display: block;
    padding: 0.85rem;
    overflow-x: auto;
    border: 1px solid rgba(148, 163, 184, 0.18);
    border-radius: 6px;
    background: rgba(2, 6, 23, 0.42);
    color: var(--text-primary);
    font-family: var(--sl-font-mono);
    font-size: 0.78rem;
    line-height: 1.65;
  }

  .entry-section,
  .platform-section,
  .workflow-section,
  .task-section,
  .capability-section,
  .trust-section {
    padding: 3rem 0;
    border-bottom: 1px solid var(--home-border);
  }

  .section-heading {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: 2rem;
    align-items: start;
    margin-bottom: 1.5rem;
  }

  .section-heading h2,
  .workflow-copy h2,
  .capability-card h2,
  .trust-section h2 {
    margin: 0.45rem 0 0;
    color: var(--text-primary);
    font-size: 1.45rem;
    line-height: 1.25;
    letter-spacing: 0;
  }

  .section-heading p,
  .workflow-copy p,
  .capability-card p {
    margin: 0;
    color: var(--home-muted);
    line-height: 1.7;
  }

  .entry-grid,
  .platform-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .platform-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .entry-card,
  .platform-card,
  .workflow-panel,
  .task-grid a,
  .capability-card,
  .trust-links a {
    border: 1px solid var(--home-border);
    border-radius: 8px;
    background: var(--home-card);
  }

  .entry-card {
    display: flex;
    min-height: 17.5rem;
    flex-direction: column;
    padding: 1rem;
    color: inherit;
    transition: border-color 150ms ease, background-color 150ms ease;
  }

  .entry-card:hover,
  .platform-card:hover,
  .task-grid a:hover,
  .trust-links a:hover {
    border-color: rgba(20, 184, 166, 0.58);
    background: var(--home-card-hover);
  }

  .icon-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    margin-bottom: 1rem;
    border: 1px solid rgba(20, 184, 166, 0.25);
    border-radius: 8px;
    background: rgba(20, 184, 166, 0.08);
    color: var(--color-brand);
  }

  .icon-box.compact {
    width: 2rem;
    height: 2rem;
    margin: 0;
  }

  .icon-box :global(svg) {
    width: 1.15rem;
    height: 1.15rem;
  }

  .entry-card strong {
    color: var(--text-primary);
    font-size: 1rem;
    line-height: 1.35;
  }

  .entry-card p,
  .platform-card p,
  .workflow-steps p {
    margin: 0.55rem 0 0;
    color: var(--home-muted);
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .entry-card code {
    display: block;
    min-height: 4.6rem;
    margin: 1rem 0;
    padding: 0.75rem;
    white-space: pre-wrap;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 6px;
    background: rgba(2, 6, 23, 0.38);
    color: var(--text-primary);
    font-family: var(--sl-font-mono);
    font-size: 0.72rem;
    line-height: 1.6;
  }

  .card-link {
    margin-top: auto;
    color: var(--color-brand);
    font-size: 0.875rem;
    font-weight: 700;
  }

  .platform-card {
    padding: 1rem;
    transition: border-color 150ms ease, background-color 150ms ease;
  }

  .platform-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .platform-card h3 {
    margin: 0;
    color: var(--text-primary);
    font-size: 1rem;
    letter-spacing: 0;
  }

  .platform-card ul {
    display: grid;
    gap: 0.55rem;
    margin: 1rem 0 0;
    padding: 0;
    list-style: none;
  }

  .platform-card li::before {
    display: none;
  }

  .platform-card a {
    justify-content: space-between;
    color: var(--home-muted);
    font-size: 0.88rem;
  }

  .platform-card a:hover {
    color: var(--color-brand);
  }

  .workflow-panel {
    display: grid;
    grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
    gap: 2rem;
    padding: 1.25rem;
  }

  .workflow-copy a {
    margin-top: 1.25rem;
    color: var(--color-brand);
    font-weight: 700;
  }

  .workflow-steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .workflow-steps div {
    min-height: 11rem;
    padding: 1rem;
    border: 1px solid var(--home-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
  }

  .workflow-steps span {
    display: block;
    color: var(--color-brand);
    font-family: var(--sl-font-mono);
    font-size: 0.75rem;
    font-weight: 700;
  }

  .workflow-steps strong {
    display: block;
    margin-top: 0.55rem;
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .task-grid,
  .trust-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.75rem;
  }

  .task-grid a,
  .trust-links a {
    justify-content: space-between;
    min-height: 3.25rem;
    padding: 0.85rem 1rem;
    color: var(--text-primary);
    font-weight: 700;
    transition: border-color 150ms ease, background-color 150ms ease;
  }

  .capability-card {
    display: grid;
    grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
    gap: 2rem;
    padding: 1.25rem;
  }

  .capability-card dl {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
  }

  .capability-card dl div {
    padding: 1rem;
    border: 1px solid var(--home-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
  }

  .capability-card dt {
    color: var(--color-brand);
    font-size: 0.75rem;
    font-weight: 750;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .capability-card dd {
    margin: 0.5rem 0 0;
    color: var(--text-primary);
    font-size: 0.95rem;
    line-height: 1.45;
  }

  .trust-section {
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(0, 1.3fr);
    gap: 2rem;
    align-items: start;
    border-bottom: 0;
  }

  .trust-links {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  :global([data-theme="light"]) .docs-home {
    --home-border: rgba(148, 163, 184, 0.35);
    --home-border-strong: rgba(107, 114, 128, 0.42);
    --home-card: #ffffff;
    --home-card-hover: rgba(13, 148, 136, 0.06);
  }

  :global([data-theme="light"]) .entry-card code,
  :global([data-theme="light"]) .hero-quickstart code {
    background: #f8fafc;
    color: #111827;
  }

  :global([data-theme="light"]) .workflow-steps div,
  :global([data-theme="light"]) .capability-card dl div {
    background: #f8fafc;
  }

  @media (max-width: 72rem) {
    .entry-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .platform-grid,
    .workflow-steps,
