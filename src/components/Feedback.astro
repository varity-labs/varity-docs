---
// Feedback widget - "Was this helpful?" buttons
// Simple localStorage tracking (can be upgraded to analytics later)
---

<div class="feedback-widget">
  <p class="feedback-question">Was this page helpful?</p>
  <div class="feedback-buttons">
    <button class="feedback-yes" data-response="yes">
      <span class="feedback-icon">👍</span>
      <span class="feedback-label">Yes</span>
    </button>
    <button class="feedback-no" data-response="no">
      <span class="feedback-icon">👎</span>
      <span class="feedback-label">No</span>
    </button>
  </div>
  <div class="feedback-thanks" style="display: none;">
    <span class="thanks-icon">✓</span>
    <span>Thanks for your feedback!</span>
  </div>
</div>

<script>
  // Track feedback for the current page
  function trackFeedback(response: string) {
    const page = window.location.pathname;

    // Store in localStorage
    localStorage.setItem(`feedback-${page}`, response);
    localStorage.setItem(`feedback-${page}-timestamp`, new Date().toISOString());

    // Show thank you message
    const thanksEl = document.querySelector('.feedback-thanks') as HTMLElement;
    const buttonsEl = document.querySelector('.feedback-buttons') as HTMLElement;

    if (thanksEl && buttonsEl) {
      buttonsEl.style.display = 'none';
      thanksEl.style.display = 'flex';
    }

    // TODO: Send to analytics when implemented
    console.log('Feedback recorded:', { page, response, timestamp: new Date().toISOString() });
  }

  // Check if user already provided feedback for this page
  function checkExistingFeedback() {
    const page = window.location.pathname;
    const existingFeedback = localStorage.getItem(`feedback-${page}`);

    if (existingFeedback) {
      const thanksEl = document.querySelector('.feedback-thanks') as HTMLElement;
      const buttonsEl = document.querySelector('.feedback-buttons') as HTMLElement;

      if (thanksEl && buttonsEl) {
        buttonsEl.style.display = 'none';
        thanksEl.style.display = 'flex';
      }
    }
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    checkExistingFeedback();

    // Add click handlers
    const buttons = document.querySelectorAll('.feedback-widget button[data-response]');
    buttons.forEach(button => {
      button.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const response = target.getAttribute('data-response');
        if (response) {
          trackFeedback(response);
        }
      });
    });
  });
</script>

<style>
  .feedback-widget {
    margin-top: 3rem;
    padding: 1.5rem 1rem;
    border-top: 1px solid var(--sl-color-hairline-light);
    text-align: center;
  }

  .feedback-question {
    font-size: 0.875rem;
    color: var(--sl-color-gray-3);
    margin: 0 0 0.75rem 0;
    font-weight: 500;
  }

  .feedback-buttons {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    align-items: center;
  }

  .feedback-buttons button {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: 0.375rem;
    border: 1px solid var(--sl-color-hairline);
    background: transparent;
    color: var(--sl-color-white);
    cursor: pointer;
    transition: all 150ms ease;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .feedback-buttons button:hover {
    background: var(--sl-color-gray-6);
    border-color: var(--sl-color-accent);
    transform: translateY(-1px);
  }

  .feedback-buttons button:active {
    transform: translateY(0);
  }

  .feedback-icon {
    font-size: 1rem;
    line-height: 1;
  }

  .feedback-label {
    line-height: 1;
  }

  .feedback-thanks {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    color: var(--sl-color-green);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 0.5rem;
  }

  .thanks-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    background: var(--sl-color-green);
    color: var(--sl-color-black);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: bold;
  }

  /* Dark mode adjustments */
  :root[data-theme='dark'] .feedback-widget {
    border-top-color: var(--sl-color-hairline-shade);
  }

  :root[data-theme='dark'] .feedback-question {
    color: var(--sl-color-gray-2);
  }

  :root[data-theme='dark'] .feedback-buttons button {
    border-color: var(--sl-color-hairline-shade);
  }

  :root[data-theme='dark'] .feedback-buttons button:hover {
    background: var(--sl-color-gray-5);
  }
</style>
