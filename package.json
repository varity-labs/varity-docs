    "test:setup": "node tests/test-docs.cjs --setup"
  },
  "dependencies": {
    "@astrojs/starlight": "^0.37.4",
    "astro": "^5.6.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "cheerio": "^1.0.0",
    "node-fetch": "^2.7.0",
